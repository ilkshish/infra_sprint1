server {
    server_name taski4pr.serveirc.com;

    location / {
        proxy_set_header Host $host;
        proxy_pass http://127.0.0.1:8000;
    }

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/taski4pr.serveirc.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/taski4pr.serveirc.com/privkey.pem;
}


server {
    server_name myhost4pr.serveirc.com;

    location /api/ {
	client_max_body_size 20M;
        proxy_set_header Host $host;
        proxy_pass http://127.0.0.1:8080;
    }

    location /admin/ {
	client_max_body_size 20M;
        proxy_set_header Host $host;
        proxy_pass http://127.0.0.1:8080;
    }

    location /static/ {
        alias /var/www/kittygram/static/;
    }

    location /media/ {
        alias /var/www/kittygram/media/;
    }

    location / {
        root /var/www/kittygram;
        index index.html;
        try_files $uri /index.html;
    }

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/taski4pr.serveirc.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/taski4pr.serveirc.com/privkey.pem;
}


server {
    listen 80;
    server_name taski4pr.serveirc.com myhost4pr.serveirc.com;
    return 301 https://$host$request_uri;
}
